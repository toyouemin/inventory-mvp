generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model category_sort_order {
  category   String   @id
  position   Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([position])
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model product_variants {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id      String   @db.Uuid
  size            String
  stock           Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  memo            String?
  memo2           String?
  sku             String?
  color           String?
  gender          String?
  wholesale_price Decimal? @default(0) @db.Decimal
  msrp_price      Decimal? @default(0) @db.Decimal
  sale_price      Decimal? @default(0) @db.Decimal
  extra_price     Decimal? @default(0) @db.Decimal
  products        products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([sku, color, gender, size])
  @@index([sku], map: "idx_product_variants_sku")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String?
  sku              String?            @unique(map: "products_sku_unique")
  category         String?
  stock            Int?
  created_at       DateTime?          @db.Timestamp(6)
  name_spec        String?
  image_url        String?
  ship_price       Int?
  msrp_price       Int?
  memo             String?
  wholesale_price  Decimal?           @db.Decimal
  sale_price       Decimal?           @db.Decimal
  updated_at       DateTime?          @db.Timestamptz(6)
  extra_price      Int?
  memo2            String?
  stock_updated_at DateTime?          @db.Timestamptz(6)
  product_variants product_variants[]

  @@index([stock_updated_at(sort: Desc)], map: "idx_products_stock_updated_at")
}
model SizeAnalysisJob {
  id               String   @id @default(cuid())
  fileName         String
  fileType         String
  workbookSnapshot Json
  selectedSheetName String?
  structureType    SizeAnalysisStructureType @default(unknown)
  headerRowIndex   Int?
  verificationJson Json?
  createdAt        DateTime @default(now())

  sheets           SizeAnalysisSheet[]
  mappings         SizeAnalysisFieldMapping[]
  rows             SizeAnalysisRow[]
}

model SizeAnalysisSheet {
  id             String  @id @default(cuid())
  jobId          String
  name           String
  rowCount       Int
  colCount       Int
  previewRows    Json?
  detectedHeader Int?
  detectedType   SizeAnalysisStructureType @default(unknown)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job            SizeAnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SizeAnalysisFieldMapping {
  id             String @id @default(cuid())
  jobId          String
  sheetName      String
  structureType  SizeAnalysisStructureType
  headerRowIndex Int?
  mappingJson    Json
  userConfirmed  Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job            SizeAnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SizeAnalysisRow {
  id                 String @id @default(cuid())
  jobId              String
  sourceSheet        String
  sourceRowIndex     Int
  sourceGroupIndex   Int?
  clubNameRaw        String?
  memberNameRaw      String?
  genderRaw          String?
  itemRaw            String?
  sizeRaw            String?
  qtyRaw             String?
  clubNameNormalized String?
  genderNormalized   String?
  standardizedSize   String?
  qtyParsed          Int?
  parseStatus        SizeAnalysisParseStatus @default(unresolved)
  parseConfidence    Float @default(0)
  parseReason        String?
  userCorrected      Boolean @default(false)
  excluded           Boolean @default(false)
  // excludeReason: duplicate_gender_filter | duplicate_first_row_kept | duplicate_same_size
  excludeReason      String?
  excludeDetail      String?
  metaJson           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  job                SizeAnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model SizeAnalysisTemplate {
  id        String   @id @default(cuid())
  name      String
  patternJson Json?
  mappingJson Json?
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SizeAliasRule {
  id            String @id @default(cuid())
  alias         String
  canonicalSize String
  confidence    Float @default(1)
  enabled       Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

enum SizeAnalysisStructureType {
  single_row_person
  repeated_slots
  size_matrix
  multi_item_personal_order
  unknown
}

enum SizeAnalysisParseStatus {
  auto_confirmed
  needs_review
  unresolved
  corrected
  excluded
}